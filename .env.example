# Azure AI Foundry Agent Configuration
# Authentication uses DefaultAzureCredential (az login / managed identity — no key needed)
# Leave blank to run in mock mode with realistic sample findings
AZURE_AGENT_ENDPOINT=https://your-project.services.ai.azure.com/api/projects/your-project
AZURE_AGENT_NAME=your-agent-name
AZURE_AGENT_VERSION=1

# Force mock mode even if Azure credentials are set
MOCK_MODE=false

# Server port
PORT=3000
